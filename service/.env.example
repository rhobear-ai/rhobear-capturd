# Captur'd hosted service — environment.
# Copy to .env and fill. The service RUNS without these (dev login + honest
# "not configured" states); these are the ONLY things that flip it fully live.

# ---- service ----
CAPTURD_BASE_URL=https://capturd.rhobear.ai       # your public URL
CAPTURD_SESSION_SECRET=                            # any long random string (generated if blank)
CAPTURD_EDITION=hosted                             # hosted | enterprise (self-host = same code)

# ---- THE HARD STOPS (owner credentials — the buy button needs these) --------
# A Stripe Payment Link or PayPal subscribe URL. "Upgrade" redirects straight
# here; we append ?client_reference_id=<user> so the webhook knows who paid.
PRO_CHECKOUT_URL=
# The webhook signing secret so "payment succeeded" auto-flips the user to Pro.
# Create at Stripe → Developers → Webhooks → endpoint https://<domain>/billing/webhook
# (event checkout.session.completed), paste the signing secret (whsec_...) here.
BILLING_WEBHOOK_SECRET=

# ---- Google sign-in (dev login covers everything until this is set) ---------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# When OAuth is live you can turn dev login off:
CAPTURD_DEV_LOGIN=1

# ---- optional: agent self-drive (Director tightens shots; keyless works too) -
RHOBEAR_GW_API_KEY=
