<?xml version="1.0" encoding="utf-8"?>
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap rescap">

  <Identity
    Name="SunSpongeLLC.Capturd"
    Publisher="CN=SunSponge LLC"
    Version="0.2.0.0" />

  <Properties>
    <DisplayName>Captur'd by Sun Sponge</DisplayName>
    <PublisherDisplayName>SunSponge LLC</PublisherDisplayName>
    <Description>Post-work product capture — stills and agent-made walkthroughs.</Description>
    <Logo>assets\sunsponge-mark.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily
      Name="Windows.Universal"
      MinVersion="10.0.17763.0"
      MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application
      Id="Capturd"
      Executable="capturd.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Captur'd by Sun Sponge"
        Description="Post-work product capture — stills and agent-made walkthroughs."
        Square150x150Logo="assets\sunsponge-mark.png"
        Square44x44Logo="assets\sunsponge-mark.png"
        BackgroundColor="transparent">
        <uap:DefaultTile Wide310x150Logo="assets\sunsponge-logo-wide.png" />
        <uap:SplashScreen Image="assets\sunsponge-logo-wide.png" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required: unrestricted local process launch for Playwright + audio device access -->
    <rescap:Capability Name="runFullTrust" />
    <!-- Required: internet access for fetching pages (shots mode) and TTS/downloads -->
    <Capability Name="internetClient" />
    <!-- Required: voice mode push-to-talk -->
    <Capability Name="microphone" />
  </Capabilities>

</Package>
